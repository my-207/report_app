@prefix : <http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection-report#> .
@prefix p: <http://www.semanticweb.org/hongt/ontologies/2026/pipeline/> .
@prefix air: <http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/> .
@prefix fac: <http://www.semanticweb.org/hongt/ontologies/2026/facility/> .
@prefix ins: <http://www.semanticweb.org/hongt/ontologies/2026/inspection/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix per: <http://www.semanticweb.org/hongt/ontologies/2026/person/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix biri: <http://www.semanticweb.org/hongt/ontologies/2026/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection-report#> .

<http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection-report> rdf:type owl:Ontology ;
                                                                             dcterms:created "2026-06-07"^^xsd:date ;
                                                                             dcterms:creator "Mavis AI Agent" ;
                                                                             dcterms:description "本本体定义了管道年度检查报告中涉及的所有实体、属性和关系，支持跨管道类型的数据标准化和知识图谱构建。"@zh ;
                                                                             rdfs:comment "长输油气管道年度检查报告的本体模型，用于知识图谱提取和数据表示"@zh ;
                                                                             rdfs:label "年度检查报告本体 V1.0"@zh ;
                                                                             rdfs:seeAlso biri: ;
                                                                             owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://qudt.org/schema/qudt/unit
qudt:unit rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/审核签名时间
air:审核签名时间 rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/批准签名时间
air:批准签名时间 rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/校对签名时间
air:校对签名时间 rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检测签名时间
air:检测签名时间 rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/设施类型
air:设施类型 rdf:type owl:AnnotationProperty ;
         rdfs:comment "地面装置的具体类型标注（建议通过rdf:type表达具体类型，此属性仅用于标注/兼容）"@zh ;
         rdfs:label "设施类型"@zh ;
         rdfs:range owl:Thing ;
         rdfs:domain air:地面装置 .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/防腐层等级
air:防腐层等级 rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#minInclusive
xsd:minInclusive rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://org.semanticweb.owlapi/error#Error5
<http://org.semanticweb.owlapi/error#Error5> rdf:type rdfs:Datatype .


###  http://org.semanticweb.owlapi/error#Error6
<http://org.semanticweb.owlapi/error#Error6> rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYearMonth
xsd:gYearMonth rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/位于管道
air:位于管道 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:range air:管道 ;
         rdfs:comment "设施所在的管道"@zh ;
         rdfs:label "位于管道"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/包含检查项目
air:包含检查项目 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:年度检查报告 ;
           rdfs:range owl:Thing ;
           rdfs:label "包含检查项目"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/地质灾害类型
air:地质灾害类型 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:地质条件调查 ;
           rdfs:range air:地质灾害类型 .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/安全管理人员
air:安全管理人员 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:使用单位 ;
           rdfs:range air:人员 ;
           rdfs:label "安全管理人员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/审核人员
air:审核人员 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain owl:Thing ;
         rdfs:range air:人员 ;
         rdfs:comment "审核报告的人员"@zh ;
         rdfs:label "审核人员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/审核签名
air:审核签名 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:审核员 ;
         rdfs:comment "审核人员签名，含时间"@zh ;
         rdfs:label "审核签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/归属单位
air:归属单位 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:管道 ;
         rdfs:range air:使用单位 ;
         rdfs:comment "管道所属的使用单位"@zh ;
         rdfs:label "归属单位"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/所属单位
air:所属单位 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:人员 ;
         rdfs:range air:使用单位 ;
         rdfs:comment "人员所属的工作单位"@zh ;
         rdfs:label "所属单位"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/所属检查项签名
air:所属检查项签名 rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain air:资料审查 ;
            rdfs:range air:检查项签名 ;
            rdfs:comment "关联该检查项的签名块（检测+校对或检测+审核）"@zh ;
            rdfs:label "所属检查项签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/所属管道
air:所属管道 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:管道 ;
         rdfs:comment "报告所检测的管道"@zh ;
         rdfs:label "所属管道"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/批准人员
air:批准人员 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:人员 ,
                    air:批准人 ;
         rdfs:comment "批准报告的人员"@zh ,
                      "报告批准人（关联年度检查报告的封面结论页）"@zh ;
         rdfs:label "批准人员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/批准签名
air:批准签名 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:批准人 ;
         rdfs:comment "批准人签名，含时间"@zh ;
         rdfs:label "批准签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/校对签名
air:校对签名 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:校对员 ;
         rdfs:comment "校对人员签名，含时间"@zh ;
         rdfs:label "校对签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检查签名人
air:检查签名人 rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain air:年度检查报告 ;
          rdfs:range air:检验员 ;
          rdfs:comment "报告封面结论页的检查签署人（检验员角色）"@zh ;
          rdfs:label "检查签名人"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检查结论
air:检查结论 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:检查结论 .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检查项审核员
air:检查项审核员 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:检查项签名 ;
           rdfs:range air:审核员 ;
           rdfs:comment "该检查项的审核人员（专项检测章节）"@zh ;
           rdfs:label "检查项审核员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检查项校对员
air:检查项校对员 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:检查项签名 ;
           rdfs:range air:校对员 ;
           rdfs:comment "该检查项的校对人员（基础章节）"@zh ;
           rdfs:label "检查项校对员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检查项检测人
air:检查项检测人 rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain air:检查项签名 ;
           rdfs:range air:检测员 ;
           rdfs:comment "该检查项的检测操作人员"@zh ;
           rdfs:label "检查项检测人"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检测人员
air:检测人员 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain owl:Thing ;
         rdfs:range air:人员 ;
         rdfs:comment "执行检测的人员"@zh ;
         rdfs:label "检测人员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/检测签名
air:检测签名 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:检测员 ;
         rdfs:comment "检测人员签名，含时间"@zh ;
         rdfs:label "检测签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/穿越方式
air:穿越方式 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:穿越段 ;
         rdfs:range air:穿越方式 .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/管理单位
air:管理单位 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:管道 ;
         rdfs:range air:使用单位 ;
         rdfs:comment "管道管理单位（区别于使用单位/注册单位）"@zh ;
         rdfs:label "管理单位"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/编制签名
air:编制签名 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:年度检查报告 ;
         rdfs:range air:编制人 ;
         rdfs:comment "编制人签名，含时间"@zh ;
         rdfs:label "编制签名"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/设施状态
air:设施状态 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:地面装置 ;
         rdfs:range air:设施状态 .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/阀室类型
air:阀室类型 rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain air:阀室 ;
         rdfs:range air:阀室类型 .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/上次检验报告编号
air:上次检验报告编号 rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain air:管道 ;
             rdfs:range xsd:string ;
             rdfs:label "上次检验报告编号"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/上次检验日期
air:上次检验日期 rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain air:管道 ;
           rdfs:range xsd:date ;
           rdfs:label "上次检验日期"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/事件发生位置
air:事件发生位置 rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain air:资料审查事件记载 ;
           rdfs:range xsd:string ;
           rdfs:comment "事件发生位置（桩号+偏移量）"@zh ;
           rdfs:label "事件发生位置"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/事件发生时间
air:事件发生时间 rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain air:资料审查事件记载 ;
           rdfs:range xsd:date ;
           rdfs:comment "管道运行期间发生的事件时间"@zh ;
           rdfs:label "事件发生时间"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/事件类型
air:事件类型 rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain air:资料审查事件记载 ;
         rdfs:range xsd:string ;
         rdfs:comment "事件类型，如外腐蚀穿孔、内腐蚀穿孔、环焊缝开裂、螺旋焊缝开裂等"@zh ;
         rdfs:label "事件类型"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/事件详细描述
air:事件详细描述 rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain air:资料审查事件记载 ;
           rdfs:range xsd:string ;
           rdfs:comment "事件起因和过程的详细描述"@zh ;
           rdfs:label "事件详细描述"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流干扰电压最大值
air:交流干扰电压最大值 rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain air:交流干扰防护数据 ;
              rdfs:range xsd:double ;
              qudt:unit unit:V ;
              rdfs:comment "交流干扰电压最大值，单位：伏特(V)"@zh ;
              rdfs:label "交流干扰电压最大值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流干扰电压最小值
air:交流干扰电压最小值 rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain air:交流干扰防护数据 ;
              rdfs:range xsd:double ;
              qudt:unit unit:V ;
              rdfs:comment "交流干扰电压最小值，单位：伏特(V)"@zh ;
              rdfs:label "交流干扰电压最小值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流排流量
air:交流排流量 rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain air:交流干扰防护数据 ;
          rdfs:range xsd:double ;
          qudt:unit unit:A ;
          rdfs:comment "交流排流量，单位：安培(A)"@zh ;
          rdfs:label "交流排流量"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电压平均值
air:交流电压平均值 rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain air:交流电压测试数据 ;
            rdfs:range xsd:double ;
            qudt:unit unit:V ;
            rdfs:comment "交流干扰电压平均值，单位：伏特(V)"@zh ;
            rdfs:label "交流电压平均值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电压最大值
air:交流电压最大值 rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain air:交流电压测试数据 ;
            rdfs:range xsd:double ;
            qudt:unit unit:V ;
            rdfs:comment "交流干扰电压最大值，单位：伏特(V)"@zh ;
            rdfs:label "交流电压最大值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电压最小值
air:交流电压最小值 rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain air:交流电压测试数据 ;
            rdfs:range xsd:double ;
            qudt:unit unit:V ;
            rdfs:comment "交流干扰电压最小值，单位：伏特(V)"@zh ;
            rdfs:label "交流电压最小值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电流密度平均值
air:交流电流密度平均值 rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain air:交流电压测试数据 ;
              rdfs:range xsd:double ;
              qudt:unit unit:A_PER_M2 ;
              rdfs:comment "交流电流密度平均值，单位：安培/平方米(A/m²)"@zh ;
              rdfs:label "交流电流密度平均值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电流密度最大值
air:交流电流密度最大值 rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain air:交流电压测试数据 ;
              rdfs:range xsd:double ;
              qudt:unit unit:A_PER_M2 ;
              rdfs:comment "交流电流密度最大值，单位：安培/平方米(A/m²)"@zh ;
              rdfs:label "交流电流密度最大值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电流密度最小值
air:交流电流密度最小值 rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain air:交流电压测试数据 ;
              rdfs:range xsd:double ;
              qudt:unit unit:A_PER_M2 ;
              rdfs:comment "交流电流密度最小值，单位：安培/平方米(A/m²)"@zh ;
              rdfs:label "交流电流密度最小值"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/位置
air:位置 rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:range xsd:string ;
       rdfs:comment "设施的位置或桩号"@zh ;
       rdfs:label "位置"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/使用年限
air:使用年限 rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain air:管道 ;
         rdfs:range xsd:integer ;
         rdfs:label "使用年限"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/使用登记证编号
air:使用登记证编号 rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain air:管道 ;
