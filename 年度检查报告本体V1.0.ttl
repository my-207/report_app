#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection-report#检测观测数据
:检测观测数据 rdf:type owl:Class .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection-report#管道系统
:管道系统 rdf:type owl:Class .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/三桩一牌
air:三桩一牌 rdf:type owl:Class ;
         rdfs:subClassOf air:地面装置 ;
         rdfs:comment "管道沿线标准组合标识设施：测试桩+标志桩+转角桩+警示牌"@zh ;
         rdfs:label "三桩一牌"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交叉测试桩
air:交叉测试桩 rdf:type owl:Class ;
          rdfs:subClassOf air:测试桩 ;
          rdfs:comment "设置在管道交叉位置处的测试桩"@zh ;
          rdfs:label "交叉测试桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流干扰防护数据
air:交流干扰防护数据 rdf:type owl:Class ;
             rdfs:subClassOf :检测观测数据 ;
             rdfs:comment "管道交流干扰防护（排流）检测数据"@zh ;
             rdfs:label "交流干扰防护数据"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/交流电压测试数据
air:交流电压测试数据 rdf:type owl:Class ;
             rdfs:subClassOf :检测观测数据 ;
             rdfs:comment "管道沿线交流干扰电压测试数据"@zh ;
             rdfs:label "交流电压测试数据"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/人员
air:人员 rdf:type owl:Class ;
       rdfs:subClassOf owl:Thing ;
       rdfs:comment "参与检测和审核的人员"@zh ;
       rdfs:label "人员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/使用单位
air:使用单位 rdf:type owl:Class ;
         rdfs:subClassOf owl:Thing ;
         rdfs:comment "管道使用单位/管理单位"@zh ;
         rdfs:label "使用单位"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/光缆标志桩
air:光缆标志桩 rdf:type owl:Class ;
          rdfs:subClassOf air:标志桩 ;
          rdfs:comment "标识光缆位置的标志桩"@zh ;
          rdfs:label "光缆标志桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/光缆桩
air:光缆桩 rdf:type owl:Class ;
        rdfs:subClassOf air:标志桩 ;
        rdfs:comment "与光缆相关的标识桩"@zh ;
        rdfs:label "光缆桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/分界标志桩
air:分界标志桩 rdf:type owl:Class ;
          rdfs:subClassOf air:标志桩 ;
          rdfs:comment "标识管道分界位置的标志桩"@zh ;
          rdfs:label "分界标志桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/加密桩
air:加密桩 rdf:type owl:Class ;
        rdfs:subClassOf air:标志桩 ;
        rdfs:comment "管道加密段的标识桩"@zh ;
        rdfs:label "加密桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/变壁厚标志桩
air:变壁厚标志桩 rdf:type owl:Class ;
           rdfs:subClassOf air:标志桩 ;
           rdfs:comment "标识管道壁厚变化位置的标志桩"@zh ;
           rdfs:label "变壁厚标志桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/地质条件调查
air:地质条件调查 rdf:type owl:Class ;
           rdfs:subClassOf owl:Thing ;
           rdfs:comment "管道沿线地质条件调查"@zh ;
           rdfs:label "地质条件调查"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/地质灾害类型
air:地质灾害类型 rdf:type owl:Class .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/地面装置
air:地面装置 rdf:type owl:Class ;
         rdfs:subClassOf :管道系统 ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty air:位于管道 ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onClass air:管道
                         ] ;
         rdfs:comment "管道沿线地面标识设施，包括测试桩、标志桩等"@zh ;
         rdfs:label "地面装置"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/垂直转角桩
air:垂直转角桩 rdf:type owl:Class ;
          rdfs:subClassOf air:转角桩 ;
          rdfs:comment "标识管道垂直方向转角的桩"@zh ;
          rdfs:label "垂直转角桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/壁厚测定
air:壁厚测定 rdf:type owl:Class ;
         rdfs:subClassOf owl:Thing ;
         rdfs:comment "管道壁厚抽样测定数据"@zh ;
         rdfs:label "壁厚测定"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/安全警告牌
air:安全警告牌 rdf:type owl:Class ;
          rdfs:subClassOf air:警示牌 ;
          rdfs:comment "管道安全警告标识牌"@zh ;
          rdfs:label "安全警告牌"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/完整性评价
air:完整性评价 rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          rdfs:comment "管道完整性评价结论和建议"@zh ;
          rdfs:label "完整性评价"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/宏观检查
air:宏观检查 rdf:type owl:Class ;
         rdfs:subClassOf owl:Thing ;
         rdfs:comment "管道宏观检查，包括位置、走向、地面装置等"@zh ;
         rdfs:label "宏观检查"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/审核员
air:审核员 rdf:type owl:Class ;
        rdfs:subClassOf air:人员 ;
        rdfs:comment "审核报告内容的人员"@zh ;
        rdfs:label "审核员"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/年度检查报告
air:年度检查报告 rdf:type owl:Class ;
           rdfs:subClassOf owl:Thing ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty air:所属管道 ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass air:管道
                           ] ;
           rdfs:comment "长输油气管道年度检查报告，包含所有检查项目的信息"@zh ;
           rdfs:label "年度检查报告"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/恒电位仪参数
air:恒电位仪参数 rdf:type owl:Class ;
           rdfs:subClassOf :检测观测数据 ;
           rdfs:comment "恒电位仪的运行参数记录"@zh ;
           rdfs:label "恒电位仪参数"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/批准人
air:批准人 rdf:type owl:Class ;
        rdfs:subClassOf air:人员 ;
        rdfs:comment "批准报告签发的人员"@zh ;
        rdfs:label "批准人"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/排流桩
air:排流桩 rdf:type owl:Class ;
        rdfs:subClassOf air:标志桩 ;
        rdfs:comment "用于交流排流保护的桩"@zh ;
        rdfs:label "排流桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/智能测试桩
air:智能测试桩 rdf:type owl:Class ;
          rdfs:subClassOf air:测试桩 ;
          rdfs:comment "带自动数据采集功能的智能测试桩"@zh ;
          rdfs:label "智能测试桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/智能电位测试桩
air:智能电位测试桩 rdf:type owl:Class ;
            rdfs:subClassOf air:智能测试桩 ,
                            air:电位测试桩 ;
            rdfs:comment "具备电位测量功能的智能测试桩"@zh ;
            rdfs:label "智能电位测试桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/标志桩
air:标志桩 rdf:type owl:Class ;
        rdfs:subClassOf air:地面装置 ;
        rdfs:comment "管道沿线各类标识设施的基类"@zh ,
                     "管道沿线的各类标识设施，包括里程桩、转角桩、穿越标志桩、光缆标志桩等"@zh ;
        rdfs:label "标志桩"@zh .


###  http://www.semanticweb.org/hongt/ontologies/2026/annual-inspection/标示桩
air:标示桩 rdf:type owl:Class ;
        rdfs:subClassOf air:标志桩 ;
